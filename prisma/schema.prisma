// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Auth (Member 2) – custom auth with bcrypt; college email only ----
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  image     String?
  college   String?  // derived from email domain, e.g. bitmesra.ac.in; used for ride filtering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews     Review[]
  rides       Ride[]
  pgListings  PGListing[]
  tiffinCenters TiffinCenter[]
  tiffinReviews TiffinReview[]
}

// ---- PG Listings (Member 3) - title, rent, location, distance, description, images (URLs) ----
model PGListing {
  id          String   @id @default(cuid())
  title       String
  rent        Int
  location    String
  distance    Float
  description String
  images      String[] // multiple photo URLs (stored in public/uploads or external)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  reviews     Review[]
}

// ---- Tiffin Centers – same structure as PG: title, rent (monthly), location, distance, description, images ----
model TiffinCenter {
  id          String   @id @default(cuid())
  title       String
  rent        Int      // monthly price in ₹
  location    String
  distance    Float
  description String
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  tiffinReviews TiffinReview[]
}

// ---- Tiffin Reviews (like Review but for TiffinCenter) ----
model TiffinReview {
  id            String       @id @default(cuid())
  rating        Int
  comment       String
  reported      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  tiffinCenterId String
  tiffinCenter   TiffinCenter @relation(fields: [tiffinCenterId], references: [id])

  @@index([tiffinCenterId])
}

// ---- Rides (Member 4) - source, destination, date, seats, contactInfo; filter by college ----
model Ride {
  id          String   @id @default(cuid())
  source      String
  destination String
  date        DateTime
  seats       Int
  college     String
  contactInfo String?  // phone/email for riders to contact creator
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

// ---- Reviews (Member 5) - API contract: listingId, rating, comment; reported flag for reports ----
model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String
  reported  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   PGListing @relation(fields: [listingId], references: [id])

  @@index([listingId])
}

// ---- Campus expansion – "Invite your campus" leads ----
model CampusRequest {
  id         String   @id @default(cuid())
  email     String
  college   String?  // college name or domain they want to add
  message   String?  // optional note
  createdAt DateTime @default(now())
}
