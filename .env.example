# Database (Neon PostgreSQL or any Postgres URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Custom auth (Member 2) – bcrypt + college email
JWT_SECRET="generate-with-openssl-rand-base64-32"
ALLOWED_EMAIL_DOMAIN="bitmesra.ac.in"

# Optional: one-click guest login for judges/demo (set both to enable "Guest login" on /login)
# GUEST_EMAIL="guest"
# GUEST_PASSWORD="your-secure-password"

# Optional: admin can delete any PG, tiffin, and ride listings (any account whose email contains "admin", e.g. admin@bitmesra.ac.in)
# No env var needed – sign up with an email that contains "admin"
